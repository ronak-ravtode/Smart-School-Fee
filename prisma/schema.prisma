datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Guardian {
  id                 Int      @id @default(autoincrement())
  name               String   @db.VarChar(100)
  mobile             String   @unique @db.VarChar(15)
  email              String   @unique @db.VarChar(100)
  passwordHash       String   @map("password_hash") @db.VarChar(255)
  role               String   @default("guardian") @db.VarChar(20) // 'admin', 'cashier', 'employee', 'guardian'
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp()

  students           Student[]
  cashierRecords     Cashier[] @relation("CashierUser")
  createdCashiers    Cashier[] @relation("CashierCreatedBy")
  approvedWaiverPenalties WaiverPenalty[] @relation("ApprovedWaiverPenalties")
  maintenanceExpenses     MaintenanceExpense[]

  @@map("guardians")
}

model Student {
  id               Int       @id @default(autoincrement())
  guardianId       Int       @map("guardian_id")
  guardian         Guardian  @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  name             String    @db.VarChar(100)
  class            String    @db.VarChar(50)
  status           String    @default("pending") @db.VarChar(20) // 'pending', 'active'
  consentChecked   Boolean   @default(false) @map("consent_checked")
  consentTimestamp DateTime? @map("consent_timestamp") @db.Timestamp()
  dob              DateTime? @db.Date
  ocrFlagged       Boolean   @default(false) @map("ocr_flagged")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamp()

  kycRecord        StudentKYC?
  assignments      FeeAssignment[]
  transactions     Transaction[]
  waiverPenalties  WaiverPenalty[]

  @@map("students")
}

model AcademicYear {
  id             Int            @id @default(autoincrement())
  label          String         @db.VarChar(100)
  startDate      DateTime       @map("start_date") @db.Date
  endDate        DateTime       @map("end_date") @db.Date
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamp()
  feeStructures  FeeStructure[]

  @@map("academic_years")
}

model FeeStructure {
  id             Int            @id @default(autoincrement())
  academicYearId Int            @map("academic_year_id")
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id])
  name           String         @db.VarChar(100)
  amount         Decimal        @db.Decimal(10, 2)
  type           String         @db.VarChar(20) // 'tuition', 'transport', 'late_fee', 'other'
  appliesTo      String         @map("applies_to") @db.VarChar(50)
  version        Int            @default(1)
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamp()
  assignments    FeeAssignment[]

  @@map("fee_structures")
}

model FeeAssignment {
  id             Int          @id @default(autoincrement())
  studentId      Int          @map("student_id")
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructureId Int          @map("fee_structure_id")
  feeStructure   FeeStructure @relation(fields: [feeStructureId], references: [id])
  dueDate        DateTime     @map("due_date") @db.Date
  status         String       @default("pending") @db.VarChar(20) // 'pending', 'paid', 'waived', 'overdue'
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamp()
  transactions   Transaction[]
  waiverPenalties WaiverPenalty[]

  @@map("fee_assignments")
}

model StudentKYC {
  id             Int       @id @default(autoincrement())
  studentId      Int       @unique @map("student_id")
  student        Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  docType        String    @map("doc_type") @db.VarChar(50) // 'aadhaar', 'birth_certificate'
  docRef         String?   @map("doc_ref") @db.VarChar(50)  // masked
  ocrData        Json      @map("ocr_data")
  ocrFlagged     Boolean   @default(false) @map("ocr_flagged")
  verifiedAt     DateTime? @map("verified_at") @db.Timestamp()
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamp()

  // Banking details (Stage 2 KYC, populated on demand)
  bankAccount       String?   @map("bank_account") @db.VarChar(255) // Encrypted string
  ifsc              String?   @db.VarChar(255) // Encrypted string
  passbookPhotoUrl  String?   @map("passbook_photo_url") @db.VarChar(255)
  isBankingComplete Boolean   @default(false) @map("is_banking_complete")

  @@map("student_kyc")
}

model Cashier {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique @map("user_id")
  user             Guardian @relation("CashierUser", fields: [userId], references: [id], onDelete: Cascade)
  createdByAdminId Int      @map("created_by_admin_id")
  createdByAdmin   Guardian @relation("CashierCreatedBy", fields: [createdByAdminId], references: [id])
  status           String   @default("active") @db.VarChar(20) // 'active', 'inactive'
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamp()

  @@map("cashiers")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  actorId   Int?     @map("actor_id")
  actorRole String?  @map("actor_role") @db.VarChar(20)
  action    String   @db.VarChar(100) // e.g. 'signup', 'create_cashier', 'update_consent'
  entity    String   @db.VarChar(50)  // e.g. 'guardian', 'student'
  entityId  Int?     @map("entity_id")
  before    Json?
  after     Json?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp()

  @@map("audit_logs")
}

model Transaction {
  id               Int           @id @default(autoincrement())
  studentId        Int           @map("student_id")
  student          Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeAssignmentId  Int           @map("fee_assignment_id")
  feeAssignment    FeeAssignment @relation(fields: [feeAssignmentId], references: [id])
  amount           Decimal       @db.Decimal(10, 2)
  method           String        @db.VarChar(20) // 'UPI', 'CASH', 'CHEQUE'
  status           String        @default("pending") @db.VarChar(20) // 'pending', 'success', 'failed', 'reversed'
  gatewayRef       String?       @map("gateway_ref") @db.VarChar(100) // Cashfree order ID
  receiptNumber    String?       @unique @map("receipt_number") @db.VarChar(50) // e.g. 'REC-2026-0001'
  depositedAt      DateTime?     @map("deposited_at") @db.Timestamp() // NULL if cash not yet deposited
  idempotencyKey   String?       @unique @map("idempotency_key") @db.VarChar(100)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamp()

  chequeRecords    ChequeRecord[]
  receiptRecord    Receipt?

  @@map("transactions")
}

model ChequeRecord {
  id             Int         @id @default(autoincrement())
  transactionId  Int         @map("transaction_id")
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  chequeNo       String      @map("cheque_no") @db.VarChar(50)
  bank           String      @db.VarChar(100)
  depositStatus  String      @default("deposit_pending") @map("deposit_status") @db.VarChar(20) // 'deposit_pending', 'bank_pending', 'cleared', 'bounced'
  bounceReason   String?     @map("bounce_reason") @db.VarChar(255)
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamp()

  @@map("cheque_records")
}

model Receipt {
  id             Int         @id @default(autoincrement())
  transactionId  Int         @unique @map("transaction_id")
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  receiptNumber  String      @unique @map("receipt_number") @db.VarChar(50)
  fileUrl        String      @map("file_url") @db.Text
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamp()

  @@map("receipts")
}

model WaiverPenalty {
  id              Int           @id @default(autoincrement())
  studentId       Int           @map("student_id")
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeAssignmentId Int           @map("fee_assignment_id")
  feeAssignment   FeeAssignment @relation(fields: [feeAssignmentId], references: [id])
  amount          Decimal       @db.Decimal(10, 2)
  type            String        @db.VarChar(20) // 'waiver', 'penalty'
  reason          String        @db.VarChar(255)
  status          String        @default("pending") @db.VarChar(20) // 'pending', 'approved', 'rejected'
  rejectionReason String?       @map("rejection_reason") @db.VarChar(255)
  approvedById    Int?          @map("approved_by_id")
  approvedBy      Guardian?     @relation("ApprovedWaiverPenalties", fields: [approvedById], references: [id])
  approvedAt      DateTime?     @map("approved_at") @db.Timestamp()
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp()

  @@map("waivers_penalties")
}


model MaintenanceExpense {
  id          Int      @id @default(autoincrement())
  description String   @db.VarChar(255)
  amount      Decimal  @db.Decimal(10, 2)
  date        DateTime @db.Date
  category    String   @db.VarChar(50) // 'watchman', 'cleaning', 'utilities', 'repairs', 'other'
  createdById Int      @map("created_by_id")
  createdBy   Guardian @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()

  @@map("maintenance_expenses")
}
